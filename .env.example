# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Keycard
KEYCARD_STS_URL=https://<zone-id>.keycard.cloud/oauth/token
KEYCARD_CLIENT_ID=your-client-id
KEYCARD_CLIENT_SECRET=your-client-secret

# Optional: override for single-agent mode (no multi-agent research preview)
# Set to "true" to skip sub-agent creation and demo tool-level authorization only
SINGLE_AGENT_MODE=false
